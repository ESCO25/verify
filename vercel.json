{
  "version": 2,
  "builds": [
    {
      "src": "api/verify.py",
      "use": "@vercel/python"
    },
    {
      "src": "public/verify.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/verify",
      "dest": "/api/verify.py"
    },
    {
      "src": "/verify.html",
      "dest": "/public/verify.html"
    },
    {
      "src": "/(.*)",
      "dest": "/public/verify.html"
    }
  ]
}
